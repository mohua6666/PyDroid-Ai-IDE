package com.pydroid.app;

import android.content.Intent;
import android.os.Bundle;
import android.os.Environment;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.Toast;
import androidx.annotation.NonNull;
import androidx.annotation.Nullable;
import androidx.fragment.app.Fragment;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;
import com.example.pydroidide.R;
import com.example.pydroidide.ui.ProjectAdapter;
import com.example.pydroidide.utils.ProjectManager;
import com.google.android.material.floatingactionbutton.FloatingActionButton;
import java.io.File;
import java.util.ArrayList;
import java.util.List;

/**
 * 文件管理 Fragment — 项目浏览、创建、删除。
 */
public class FileManagerFragment extends Fragment {

    private RecyclerView projectRecyclerView;
    private FloatingActionButton fabNewProject;

    private ProjectManager projectManager;
    private ProjectAdapter adapter;
    private List<File> projects = new ArrayList<>();

    @Nullable
    @Override
    public View onCreateView(@NonNull LayoutInflater inflater, @Nullable ViewGroup container,
                             @Nullable Bundle savedInstanceState) {
        // 使用简单布局，以 RecyclerView + FAB 为主
        // 由于没有专用的 file_manager 布局，我们动态创建根视图
        View root = buildRootView(container);
        return root;
    }

    private View buildRootView(ViewGroup container) {
        // 创建根 LinearLayout + FAB 覆盖
        android.widget.FrameLayout root = new android.widget.FrameLayout(requireContext());
        root.setLayoutParams(new ViewGroup.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT,
                ViewGroup.LayoutParams.MATCH_PARENT));
        root.setBackgroundColor(0xFF0D0D1A);

        // RecyclerView
        projectRecyclerView = new RecyclerView(requireContext());
        projectRecyclerView.setLayoutParams(new android.widget.FrameLayout.LayoutParams(
                ViewGroup.LayoutParams.MATCH_PARENT,
                ViewGroup.LayoutParams.MATCH_PARENT));
        projectRecyclerView.setPadding(8, 8, 8, 8);
        projectRecyclerView.setClipToPadding(false);
        root.addView(projectRecyclerView);

        // FAB
        FloatingActionButton fab = new FloatingActionButton(requireContext());
        android.widget.FrameLayout.LayoutParams fabParams = new android.widget.FrameLayout.LayoutParams(
                ViewGroup.LayoutParams.WRAP_CONTENT,
                ViewGroup.LayoutParams.WRAP_CONTENT);
        fabParams.gravity = android.view.Gravity.BOTTOM | android.view.Gravity.END;
        fabParams.setMargins(0, 0, 32, 32);
        fab.setLayoutParams(fabParams);
        fab.setImageResource(android.R.drawable.ic_input_add);
        fab.setBackgroundTintList(android.content.res.ColorStateList.valueOf(0xFF00D4AA));
        fab.setImageTintList(android.content.res.ColorStateList.valueOf(0xFFFFFFFF));
        fab.setOnClickListener(v -> showCreateDialog());
        root.addView(fab);
        fabNewProject = fab;

        return root;
    }

    @Override
    public void onViewCreated(@NonNull View view, @Nullable Bundle savedInstanceState) {
        super.onViewCreated(view, savedInstanceState);

        projectManager = new ProjectManager();

        adapter = new ProjectAdapter(projects,
                project -> {
                    // 点击项目 — 打开编辑器
                    Intent intent = new Intent(getContext(), EditorActivity.class);
                    intent.putExtra("project_path", project.getAbsolutePath());
                    startActivity(intent);
                },
                project -> {
                    // 长按项目 — 删除确认
                    showDeleteConfirm(project);
                });

        projectRecyclerView.setLayoutManager(new LinearLayoutManager(getContext()));
        projectRecyclerView.setAdapter(adapter);

        loadProjects();
    }

    @Override
    public void onResume() {
        super.onResume();
        loadProjects(); // 返回时刷新
    }

    private void loadProjects() {
        projects.clear();
        projects.addAll(projectManager.getProjects());
        adapter.updateProjects(projects);
    }

    private void showCreateDialog() {
        android.app.AlertDialog.Builder builder = new android.app.AlertDialog.Builder(requireContext());
        builder.setTitle("新建项目");

        final android.widget.EditText input = new android.widget.EditText(requireContext());
        input.setHint("输入项目名称...");
        input.setTextColor(0xFFE0E0FF);
        input.setHintTextColor(0xFF8888CC);
        input.setPadding(32, 32, 32, 32);
        input.setBackgroundColor(0xFF16163A);
        builder.setView(input);

        builder.setPositiveButton("创建", (dialog, which) -> {
            String name = input.getText().toString().trim();
            if (!name.isEmpty()) {
                projectManager.createProject(name);
                loadProjects();
                Toast.makeText(getContext(), "项目 " + name + " 已创建", Toast.LENGTH_SHORT).show();
            }
        });
        builder.setNegativeButton("取消", null);
        builder.show();
    }

    private void showDeleteConfirm(File project) {
        android.app.AlertDialog.Builder builder = new android.app.AlertDialog.Builder(requireContext());
        builder.setTitle("删除项目");
        builder.setMessage("确定要删除项目 \"" + project.getName() + "\" 吗？\n此操作不可撤销！");
        builder.setPositiveButton("删除", (dialog, which) -> {
            projectManager.deleteProject(project);
            loadProjects();
            Toast.makeText(getContext(), "项目已删除", Toast.LENGTH_SHORT).show();
        });
        builder.setNegativeButton("取消", null);
        builder.show();
    }
}