package com.example.pydroidide.utils;

import android.content.Context;
import java.io.File;
import java.io.FileInputStream;
import java.io.FileOutputStream;
import java.io.IOException;
import java.nio.charset.StandardCharsets;

/**
 * 文件管理器：负责文件读写、项目创建/删除等。
 */
public class FileManager {

    public static final String DEFAULT_MAIN_PY =
        "# -*- coding: utf-8 -*-\n" +
        "#!/usr/bin/env python3\n" +
        "\"\"\"PyDroid AI - Python IDE\"\"\"\n\n" +
        "def main():\n" +
        "    print('Hello, PyDroid AI!')\n" +
        "    \n" +
        "if __name__ == '__main__':\n" +
        "    main()\n";

    /**
     * 读取文件全部内容，返回字符串（UTF-8）。
     */
    public String readFile(File file) {
        if (file == null || !file.exists()) return "";
        try (FileInputStream fis = new FileInputStream(file)) {
            byte[] data = new byte[(int) file.length()];
            int read = fis.read(data);
            return new String(data, 0, read, StandardCharsets.UTF_8);
        } catch (IOException e) {
            return "";
        }
    }

    /**
     * 将文本写入文件（覆盖）。
     */
    public void saveFile(File file, String content) {
        if (file == null) return;
        File parent = file.getParentFile();
        if (parent != null && !parent.exists()) parent.mkdirs();
        try (FileOutputStream fos = new FileOutputStream(file)) {
            fos.write(content.getBytes(StandardCharsets.UTF_8));
        } catch (IOException ignored) {
        }
    }

    /**
     * 创建默认 main.py（首次打开项目时使用）。
     */
    public void createDefaultMainPy(File file) {
        if (file != null && !file.exists()) {
            saveFile(file, DEFAULT_MAIN_PY);
        }
    }

    /**
     * 递归删除目录/文件。
     */
    public boolean deleteRecursive(File fileOrDir) {
        if (fileOrDir == null || !fileOrDir.exists()) return false;
        if (fileOrDir.isDirectory()) {
            File[] children = fileOrDir.listFiles();
            if (children != null) {
                for (File child : children) {
                    deleteRecursive(child);
                }
            }
        }
        return fileOrDir.delete();
    }
}
