<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- AI助手头部 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🤖 AI Python助手"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_clear_chat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="?android:attr/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="清空对话" />
    </LinearLayout>

    <!-- 快捷功能卡片 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="快捷AI功能"
                android:textColor="@color/accent_cyan"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_explain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖 解释代码"
                    android:textColor="#FFFFFF"
                    app:chipBackgroundColor="@color/accent_purple"
                    style="@style/Widget.MaterialComponents.Chip.Choice" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_optimize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ 优化代码"
                    android:textColor="#FFFFFF"
                    app:chipBackgroundColor="@color/accent_green"
                    style="@style/Widget.MaterialComponents.Chip.Choice" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_debug"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐛 调试分析"
                    android:textColor="#FFFFFF"
                    app:chipBackgroundColor="@color/warning_yellow"
                    style="@style/Widget.MaterialComponents.Chip.Choice" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_generate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ 生成脚本"
                    android:textColor="#FFFFFF"
                    app:chipBackgroundColor="@color/accent_pink"
                    style="@style/Widget.MaterialComponents.Chip.Choice" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_convert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄 代码转换"
                    android:textColor="#FFFFFF"
                    app:chipBackgroundColor="@color/accent_cyan"
                    style="@style/Widget.MaterialComponents.Chip.Choice" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 对话区域 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- 输入区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <EditText
            android:id="@+id/et_ai_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入你的需求，AI帮你写Python..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:background="@drawable/edit_bg"
            android:padding="12dp"
            android:maxLines="4"
            android:inputType="textMultiLine" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="?android:attr/actionModeSendDrawable"
            android:background="@drawable/send_btn_bg"
            android:contentDescription="发送" />
    </LinearLayout>
</LinearLayout>
